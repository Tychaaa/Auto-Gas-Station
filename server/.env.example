GIN_MODE=mode
PORT=port

# Windows: COM6  |  Linux: /tmp/fuel-server (после запуска start-all.sh или socat вручную)
FUEL_PORT=COM6
FUEL_ADDRESS=1
FUEL_BAUD=4800
FUEL_DATABITS=7
FUEL_STOPBITS=2
FUEL_PARITY=even

# Vendotek EzPOS: URL терминала или мока (http://localhost:8082 для разработки)
VENDOTEK_BASE_URL=http://localhost:8082
# Таймаут HTTP-запросов к терминалу (реальная оплата может занимать до 30+ сек)
VENDOTEK_TIMEOUT=30s
# Опциональный префикс к ID операции (для отладки в общей среде)
VENDOTEK_OP_ID_PREFIX=
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

DB_PATH=data/kiosk.db

# Путь к JSON со стартовыми ценами; применяется только если БД пуста.
PRICING_SEED_PATH=configs/seed_prices.json

SELECTION_PRICE_LOCK_TTL=10m

# Таймаут неактивности: через сколько времени selection-транзакция считается брошенной.
# Должен быть больше VITE_KIOSK_IDLE_TIMEOUT_MS на клиенте (клиент срабатывает первым).
TRANSACTION_IDLE_TIMEOUT=10m
# Как часто фоновый свипер проверяет и закрывает брошенные транзакции.
TRANSACTION_IDLE_SWEEP_INTERVAL=2m
# Включить/выключить фоновый свипер (true/false).
TRANSACTION_IDLE_SWEEP_ENABLED=true

# HTTP Basic Auth для /api/v1/admin/*
# Оба значения обязательны. Сервер не стартует если одно из них пустое.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# ESP32 watchdog (UART). serial — реальный обмен, disabled — заглушка
# (можно запускать сервер без железа и без мока). Когда serial — обязательно
# нужно указать WATCHDOG_PORT, на котором висит ESP32 (или вторая половина
# виртуальной COM-пары для мока server/mocks/esp32-watchdog).
WATCHDOG_MODE=disabled
# Windows: COM7  |  Linux: /tmp/esp32-server (после запуска start-all.sh или socat вручную)
WATCHDOG_PORT=COM7
WATCHDOG_BAUD=115200
WATCHDOG_HEARTBEAT_INTERVAL=5s
WATCHDOG_EXCHANGE_TIMEOUT=2s

# Онлайн-касса PayOnline-01-ФА. Чек печатается автоматически сразу после успешной оплаты.
KKT_HOST=127.0.0.1
KKT_PORT=7778
KKT_CONNECT_TIMEOUT_MS=5000
KKT_READ_TIMEOUT_MS=30000
KKT_BYTE_TIMEOUT_MS=200
KKT_ACK_TIMEOUT_MS=1000
KKT_SYSADMIN_PASSWORD=30
KKT_OPERATOR_PASSWORD=30
# Допустимые значения KKT_TAX_SYSTEM: OSN, USN_INCOME, USN_INCOME_EXPENSE, ESHN, PSN.
KKT_TAX_SYSTEM=USN_INCOME_EXPENSE
# Допустимые значения KKT_VAT_RATE: VAT_20, VAT_10, VAT_0, NO_VAT, VAT_20_120, VAT_10_110, VAT_5, VAT_7, VAT_5_105, VAT_7_107.
KKT_VAT_RATE=NO_VAT
KKT_DEPARTMENT=0
# Признак способа расчёта (тег 1214). 4 = полный расчёт.
KKT_PAYMENT_METHOD_SIGN=4
# Признак предмета расчёта (тег 1212). 1 = товар, 2 = подакцизный товар, 3 = работа, 4 = услуга.
KKT_PAYMENT_SUBJECT_SIGN=1
# Логировать hex-дампы байтового обмена с ККТ (true/false).
KKT_DUMP_HEX=false
# Порог в часах для перезапуска смены (до того как ККТ сама её просрочит). Диапазон 1..24.
KKT_SHIFT_MAX_HOURS=23
# Время автоматического закрытия смены по расписанию (формат HH:MM, местное время сервера).
KKT_AUTO_CLOSE_AT=00:00