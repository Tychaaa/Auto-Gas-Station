# Серийный порт, который слушает мок ESP32. На Windows это вторая половина
# виртуальной пары com0com (например, COM5 — сервер, COM6 — мок).
# На Linux: socat -d -d pty,raw,echo=0 pty,raw,echo=0 → /dev/pts/N и /dev/pts/M.
# Windows: COM8 (вторая половина пары com0com)  |  Linux: /tmp/esp32-mock (socat, см. start-all.sh)
MOCK_WATCHDOG_PORT=COM8

# Скорость должна совпадать с WATCHDOG_BAUD у сервера.
MOCK_WATCHDOG_BAUD=115200

# Сколько мок ждёт PING прежде чем «нажать» reset (только для логов,
# железо при этом не перезагружается).
MOCK_WATCHDOG_TIMEOUT=60s
