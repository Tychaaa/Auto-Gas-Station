GIN_MODE=debug
PORT=8082

# success / decline / timeout / reverted
VENDOTEK_DEFAULT_SCENARIO=success

# Задержка до перехода в wait_for_card (мс)
VENDOTEK_AUTO_WAIT_MS=500
# Задержка до финального статуса после wait_for_card (мс)
VENDOTEK_AUTO_DELAY_MS=1500
# Таймаут для сценария timeout (мс)
VENDOTEK_TIMEOUT_MS=600000

# Процент случайных отказов (0–100, работает со сценарием success)
VENDOTEK_RANDOM_DECLINE_PCT=0

VENDOTEK_SERIAL_NUMBER=MOCKVTK0001
# Verbose-логирование запросов/ответов
MOCK_VENDOTEK_DEBUG=false